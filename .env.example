# Copy to .env and set values. Do not commit .env with real secrets.

# For Podman build + push: set REGISTRY (e.g. docker.io/yourusername or quay.io/yourusername)
# REGISTRY=docker.io/yourusername

SPRING_PROFILES_ACTIVE=docker
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KEYCLOAK_AUTH_SERVER_URL=http://keycloak:9080
EUREKA_DEFAULT_ZONE=http://eureka-discovery-server:8761/eureka
CONFIG_SERVER_URL=http://property-config-server:8888
TIME_ZONE=Asia/Kolkata

# Use strong secrets in production; avoid defaults in prod
JWT_SECRET=your-jwt-secret-at-least-32-characters-long
ENCRYPTION_SECRET_KEY=your-encryption-secret-key
